# =============================================================================
# Hermes Orchestrator — Environment Variables
# =============================================================================

# --- HTTP server ---
PORT=8080
LOG_LEVEL=info

# --- Shared secret Sokosumi sends as `Authorization: Bearer <token>` ---
ORCHESTRATOR_API_TOKEN=replace-with-strong-random-string

# --- Postgres (Neon) ---
DATABASE_URL=postgres://USER:PASS@HOST/DB?sslmode=require

# --- Sprites.dev API ---
# Get one at https://sprites.dev (Settings → API tokens)
SPRITES_API_TOKEN=sprt_xxxxxxxxxxxxxxxxxxxxxxxx
SPRITES_API_BASE=https://api.sprites.dev
SPRITES_DEFAULT_REGION=

# --- Per-instance defaults ---
DEFAULT_IDLE_SUSPEND_MINUTES=30
PER_USER_INSTANCE_CAP=1

# --- LLM provider (orchestrator-owned; sprites never see this) ---
# Sprites get a per-instance bearer pointing at the orchestrator's LLM proxy
# (/v1/llm/:instanceId/*). The orchestrator forwards to OpenRouter with this key.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Web search (Exa). Optional. Set a spend cap on the Exa dashboard. ---
# Unlike OpenRouter this key IS injected into each sprite (Hermes' Exa client
# is hardcoded so we can't proxy it cleanly). Spend cap is the safety net.
EXA_API_KEY=

# --- Public base URL of THIS orchestrator service ---
# Sprites use this to call the orchestrator's LLM proxy. Must be the public
# Railway hostname (not the private/internal one).
ORCHESTRATOR_PUBLIC_URL=https://orchestrator-production-35d4.up.railway.app

# --- Per-instance LLM proxy rate limit (requests per minute) ---
LLM_RATE_LIMIT_RPM=60

# --- Encryption key for at-rest API_SERVER_KEY storage ---
# 32 random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=replace-with-base64-32-bytes

# --- Admin dashboard ---
# Used by HTTP Basic Auth on /admin/*. Username is literally "admin".
ADMIN_PASSWORD=replace-with-strong-random-string
