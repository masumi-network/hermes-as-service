generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HermesInstance {
  id             String   @id @default(uuid())
  userId         String   @unique
  /// Fly app name (one app per user). Also used historically as the
  /// "sprite name" — column kept for migration continuity but holds a
  /// Fly app slug now.
  spriteName     String   @unique
  /// Fly machine ID inside the per-user app. Old "sprite ID" semantically.
  spriteId       String?
  region         String
  endpointUrl    String?
  apiServerKey   String
  openRouterKey  String
  llmProxyToken  String?
  /// New: the Fly volume ID attached to the machine for /opt/data
  flyVolumeId    String?
  /// Optional human-readable display name supplied at provision time.
  /// Seeded into Hermes' memory so the agent knows who the user is.
  name           String?
  /// Optional email, same purpose. Lets Hermes do an initial public-web
  /// research pass and personalize daily suggestions.
  email          String?
  /// Optional user role/title (e.g. "Founder / CEO", "Engineering",
  /// "Marketing"). Free-form ≤64 chars. Sokosumi passes this at
  /// provision or onboard time; used to ground the research pass and
  /// the welcome message. Not access-control, just personalization.
  role           String?
  /// Optional company name the user works at, ≤120 chars. Same purpose
  /// as role — biases public-web research toward the company's domain
  /// and shapes the welcome opener.
  company        String?
  status         String
  /// Set the first time onboarding completes for this user. Persists across
  /// instance destroy/re-create cycles (HermesInstance is keyed by userId).
  /// When non-null, provision goes directly to status=ready without showing
  /// the integration screen again.
  onboardedAt    DateTime?
  /// Step-by-step progress for the onboarding loader UI. JSON array of
  /// `{ id, label, status: pending|running|done|failed }`. Updated as
  /// runOnboarding progresses so Sokosumi can render a real progress bar.
  onboardingSteps Json?
  /// Soft-delete marker. When set, the Fly app/machine/volume is gone but
  /// we keep the user's profile (name, email, onboardedAt) + integrations
  /// for re-provision on the next session. A new POST /v1/instances for
  /// the same userId re-uses this row (clearing destroyedAt + regenerating
  /// spriteName/keys) so onboardedAt persists across destroy/re-create.
  destroyedAt    DateTime?
  /// The one-shot welcome message produced by onboarding (or
  /// runReturningUserBoot). Surfaced inline in GET /v1/instances/:userId
  /// so Sokosumi can render it the moment status flips to "ready" without
  /// a separate inbox poll. Re-written on each provision cycle; cleared
  /// when a fresh provision starts. The async inbox endpoint is for
  /// post-ready pushes only (scheduled task results, daily suggestions).
  welcomeMessage String?
  /// Discriminator for welcomeMessage: "research_intro" (full Gmail-aware
  /// intro), "welcome" (generic fallback when research failed), or
  /// "returning" (short welcome-back on session 2+). Lets Sokosumi UI
  /// pick a render style if useful.
  welcomeKind    String?
  /// Last successful run of the Sokosumi workspace sync (onboarding step
  /// or recurring daily cron). The cron picks up any user whose value is
  /// >23h old. null means never synced — either Sokosumi API isn't
  /// configured or onboarding pre-dated this feature.
  lastSokosumiSyncAt DateTime?
  /// Last time the inbox-refresh cron asked Hermes to scan its connected
  /// mail/calendar MCPs and update memory. Cron picks up any user with
  /// connected mail/calendar integrations whose value is >6h old (or null).
  lastInboxRefreshAt DateTime?
  /// Last Sokosumi job completedAt the urgent-interrupt cron has already
  /// considered. Used to bound the "new completions since last check"
  /// query so we don't re-evaluate the same jobs every tick.
  lastJobNoticeAt    DateTime?
  /// Floor for proactive interrupts — Hermes pushes at most one urgent
  /// notification per 2h per user, regardless of how many events fire
  /// inside the window. Multiple events in the same window get batched
  /// into a single message at the next eligible tick.
  lastUrgentInterruptAt DateTime?
  /// Per-status watermarks for the urgent-interrupt cron's
  /// completion/awaiting-input/failed scans. Separate from lastJobNoticeAt
  /// (which tracks COMPLETED only) so a flood of completions doesn't
  /// hide a new AWAITING_INPUT event from getting noticed.
  lastAwaitingInputNoticeAt DateTime?
  lastFailedJobNoticeAt DateTime?
  /// HIGH-autonomy users get a hourly task-augmentation pass: Hermes
  /// scans newly-created tasks since this watermark and adds enriching
  /// comments where it has useful context (mail, memory, prior jobs).
  lastTaskAugmentationAt DateTime?
  /// How much autonomy Hermes has on this instance's workspace:
  ///   "low"    — read only; never starts tasks/jobs, never comments
  ///   "medium" — can do everything, but always asks the user first
  ///              (Hermes drafts confirmation in chat; user replies; fires)
  ///   "high"   — can act autonomously, including running tasks in the
  ///              background and adding comments to existing tasks
  /// Set at provision time. Default "medium". Changeable via
  /// PATCH /v1/instances/:userId.
  autonomyLevel String   @default("medium")
  /// IANA timezone (e.g. "America/New_York", "Europe/Berlin"). Used to
  /// interpret cron expressions on user-facing scheduled tasks like
  /// morning-brief or weekly-wrap. Defaults to UTC when null. Sokosumi
  /// passes this at provision time if known.
  timezone       String?
  /// Which Sokosumi backend this user lives in: "development", "preprod",
  /// or "mainnet". Sokosumi sends this at provision time so the
  /// orchestrator's sokosumi_sync routes API calls to the correct env's
  /// base URL + coworker API key. null is treated as "mainnet" for
  /// backwards compat with instances provisioned before this column existed.
  sokosumiEnv    String?
  lastActivityAt DateTime @default(now())
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages              ChatMessage[]
  provisionEvents       ProvisionEvent[]
  llmUsage              LlmUsage[]
  schedules             ScheduledTask[]
  outbox                OutboxMessage[]
  integrations          Integration[]
  pendingConfirmations  PendingConfirmation[]

  @@index([status])
  @@index([lastActivityAt])
}

/// Per-user OAuth-broker MCP connections (Composio, Arcade, etc.).
/// Survives instance destroy/re-create — on every fresh provision we replay
/// these into the new Fly machine's MCP_SERVERS_JSON env.
model Integration {
  id          String   @id @default(uuid())
  instanceId  String
  userId      String
  /// "gmail" | "google_calendar" | "outlook" | "outlook_calendar" | ...
  provider    String
  /// Encrypted MCP HTTP endpoint (e.g., Composio's per-user MCP URL).
  mcpUrl      String
  /// Encrypted bearer/API token used by Hermes to call the MCP. Can be
  /// empty if the broker bakes auth into the URL.
  mcpToken    String   @default("")
  /// "connecting" | "connected" | "failed" | "disconnected" | "pending" | "error"
  status      String   @default("connecting")
  /// "read" (default — safest) or "write". Drives the MCP proxy's
  /// tool-list filter: when "read", write-tools (SEND_*, CREATE_*,
  /// DELETE_*, etc.) are stripped from the catalog Hermes sees. Defense
  /// in depth: the OAuth scope from Composio should ALSO be read-only,
  /// but we don't rely on that as the only barrier.
  mode        String   @default("read")
  lastError   String?
  connectedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instance HermesInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([instanceId])
  @@index([status])
}

model LlmUsage {
  id               String   @id @default(uuid())
  instanceId       String
  userId           String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costUsd          Decimal  @db.Decimal(12, 6) @default(0)
  streamed         Boolean  @default(false)
  createdAt        DateTime @default(now())

  instance HermesInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([instanceId, createdAt])
  @@index([createdAt])
}

model ChatMessage {
  id               String   @id @default(uuid())
  instanceId       String
  userId           String
  requestId        String
  role             String
  content          String
  /// "chat" (default) or "scheduled" — surfaced so Sokosumi can render
  /// scheduled-result messages with a visual indicator.
  kind             String   @default("chat")
  scheduledTaskId  String?
  model            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  finishReason     String?
  latencyMs        Int?
  errorMessage     String?
  createdAt        DateTime @default(now())

  instance      HermesInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  scheduledTask ScheduledTask?  @relation(fields: [scheduledTaskId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([instanceId, createdAt])
  @@index([requestId])
  @@index([createdAt])
  @@index([scheduledTaskId])
}

model OutboxMessage {
  id         String   @id @default(uuid())
  instanceId String
  userId     String
  content    String
  kind       String   @default("text")
  createdAt  DateTime @default(now())

  instance HermesInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([instanceId, createdAt])
  @@index([createdAt])
}

model ScheduledTask {
  id           String   @id @default(uuid())
  instanceId   String
  userId       String
  name         String
  prompt       String
  /// What this schedule actually is for the user:
  ///   "user"           — created by the user (or by Hermes on user's behalf)
  ///                       via the cronjob tool. Scheduler dispatches the
  ///                       prompt to Hermes' chat completions endpoint.
  ///   "system_prompt"  — created by the orchestrator at provision (or
  ///                       autonomy change) as a recurring chat prompt
  ///                       (morning-brief, weekly-wrap, etc.). Scheduler
  ///                       dispatches it just like user prompts.
  ///   "system_sweep"   — informational mirror of an orchestrator-level
  ///                       background sweep (inbox-refresh, urgent-interrupts,
  ///                       task-augmentation). The scheduler SKIPS these
  ///                       rows; the matching orchestrator sweep reads the
  ///                       row's `enabled` flag to gate the work per user.
  kind         String   @default("user")
  /// Human-readable explanation of what this schedule does. Surfaced in
  /// Sokosumi's settings panel so users can understand the chip before
  /// toggling it off.
  description  String?
  cronExpr     String
  timezone     String   @default("UTC")
  enabled      Boolean  @default(true)
  lastRunAt    DateTime?
  lastError    String?
  nextRunAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instance HermesInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([enabled, nextRunAt])
  @@index([instanceId, kind])
}

/// At MEDIUM autonomy, write/spend tool calls don't execute. Instead the
/// MCP server records the intended call here as "pending" and the
/// Sokosumi UI renders a confirmation box. The user approves or rejects
/// via the orchestrator's /confirmations endpoints; approval triggers
/// the actual tool execution and an outbox message back to Hermes.
model PendingConfirmation {
  id            String   @id @default(uuid())
  instanceId    String
  userId        String
  /// MCP tool name, e.g. "sokosumi_create_task", "sokosumi_create_job".
  toolName      String
  /// Original arguments Hermes passed to the tool. Replayed on approval.
  toolArgs      Json
  /// Short, plain-language summary of what will happen. Rendered as the
  /// body of the in-chat confirmation box.
  summary       String
  /// "pending" | "approved" | "rejected" | "expired" | "errored"
  status        String   @default("pending")
  /// "user" | "system_timeout" | "system_cancel"
  resolvedBy    String?
  /// Tool's JSON response after successful execution (post-approval).
  resultPayload Json?
  /// Set if execution after approval failed.
  errorMessage  String?
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  instance HermesInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ProvisionEvent {
  id         String   @id @default(uuid())
  instanceId String?
  userId     String
  event      String
  detail     Json?
  createdAt  DateTime @default(now())

  instance HermesInstance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([createdAt])
}
